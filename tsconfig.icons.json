{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationDir": "dist/icons",
    "emitDeclarationOnly": true,
    "rootDir": "src/icons",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["src/icons/**/*.ts", "src/icons/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
