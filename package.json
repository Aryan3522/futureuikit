{
  "name": "futureuikit",
  "version": "0.1.9",
  "description": "Future UI component registry and installer CLI for Next.js projects.",
  "private": false,
  "license": "MIT",
  "homepage": "https://futureuikit.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aryan3522/future-ui.git"
  },
  "bugs": {
    "url": "https://github.com/Aryan3522/future-ui/issues"
  },
  "bin": {
    "futureuikit": "bin/cli.mjs"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "config": {
    "registryUrl": "https://futureuikit.vercel.app/api/registry"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cli:version": "node ./bin/cli.mjs --version",
    "prepack": "node ./bin/cli.mjs --version",
    "sync": "node scripts/sync-registry.mjs"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^6.0.3"
  }
}
